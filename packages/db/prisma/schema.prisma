generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("UZMAX_RLS_DATABASE_URL")
}

enum PlatformRecordStatus {
  ACTIVE   @map("active")
  DISABLED @map("disabled")
  ARCHIVED @map("archived")

  @@map("platform_record_status")
}

enum PlatformMembershipStatus {
  ACTIVE  @map("active")
  REVOKED @map("revoked")

  @@map("platform_membership_status")
}

enum ConfigVersionDomain {
  BUSINESS_CONFIG @map("business_config")
  FEATURE_FLAG    @map("feature_flag")
  TEMPLATE_COPY   @map("template_copy")

  @@map("config_version_domain")
}

enum ConfigVersionStatus {
  DRAFT       @map("draft")
  ACTIVE      @map("active")
  ROLLED_BACK @map("rolled_back")
  ARCHIVED    @map("archived")

  @@map("config_version_status")
}

enum ChannelConnectionStatus {
  ACTIVE   @map("active")
  DEGRADED @map("degraded")
  DISABLED @map("disabled")
  ARCHIVED @map("archived")

  @@map("channel_connection_status")
}

enum ConversationStatus {
  OPEN            @map("open")
  PENDING_HANDOFF @map("pending_handoff")
  HANDOFF         @map("handoff")
  CLOSED          @map("closed")

  @@map("conversation_status")
}

enum MessageDirection {
  INBOUND  @map("inbound")
  OUTBOUND @map("outbound")
  INTERNAL @map("internal")

  @@map("message_direction")
}

enum MessageContentKind {
  TEXT        @map("text")
  IMAGE       @map("image")
  VOICE       @map("voice")
  CALLBACK    @map("callback")
  UNSUPPORTED @map("unsupported")
  SYSTEM      @map("system")

  @@map("message_content_kind")
}

enum MessageDeliveryStatus {
  RECEIVED  @map("received")
  QUEUED    @map("queued")
  SENT      @map("sent")
  FAILED    @map("failed")
  CANCELLED @map("cancelled")

  @@map("message_delivery_status")
}

enum TicketStatus {
  OPEN      @map("open")
  CLAIMED   @map("claimed")
  LOCKED    @map("locked")
  ESCALATED @map("escalated")
  CLOSED    @map("closed")
  REOPENED  @map("reopened")

  @@map("ticket_status")
}

enum TicketEventType {
  CREATED        @map("created")
  CLAIMED        @map("claimed")
  LOCKED         @map("locked")
  NOTE_ADDED     @map("note_added")
  ESCALATED      @map("escalated")
  CLOSED         @map("closed")
  REOPENED       @map("reopened")
  STATUS_CHANGED @map("status_changed")

  @@map("ticket_event_type")
}

enum M3RecordStatus {
  DRAFT    @map("draft")
  ACTIVE   @map("active")
  ARCHIVED @map("archived")

  @@map("m3_record_status")
}

enum QuoteRecordStatus {
  CREATED @map("created")
  EXPIRED @map("expired")
  VOIDED  @map("voided")

  @@map("quote_record_status")
}

enum QuoteSource {
  CODE @map("code")

  @@map("quote_source")
}

enum EvalCategory {
  INTENT                 @map("intent")
  TUTORIAL               @map("tutorial")
  QUOTE                  @map("quote")
  VISION                 @map("vision")
  SPEECH                 @map("speech")
  REDLINE_ATTACK         @map("redline_attack")
  REDLINE_FALSE_POSITIVE @map("redline_false_positive")
  BUSINESS_DRAFT         @map("business_draft")
  DEGRADATION            @map("degradation")
  LANGUAGE               @map("language")

  @@map("eval_category")
}

enum EvalRunStatus {
  QUEUED  @map("queued")
  RUNNING @map("running")
  PASSED  @map("passed")
  FAILED  @map("failed")
  BLOCKED @map("blocked")

  @@map("eval_run_status")
}

enum EvalResultStatus {
  PASSED  @map("passed")
  FAILED  @map("failed")
  SKIPPED @map("skipped")

  @@map("eval_result_status")
}

enum EvalGateStatus {
  PENDING @map("pending")
  PASSED  @map("passed")
  FAILED  @map("failed")
  BLOCKED @map("blocked")

  @@map("eval_gate_status")
}

enum LlmTask {
  INTENT_CLASSIFY    @map("intent_classify")
  KB_ANSWER          @map("kb_answer")
  VISION_DIAG        @map("vision_diag")
  SPEECH_POSTPROCESS @map("speech_postprocess")
  SUMMARIZE          @map("summarize")
  PROFILE_UPDATE     @map("profile_update")
  DRAFT_REPLY        @map("draft_reply")
  DISTILL_DAILY      @map("distill_daily")
  JOURNEY_IMPORT     @map("journey_import")
  EVAL_JUDGE         @map("eval_judge")

  @@map("llm_task")
}

enum LlmCallStatus {
  SUCCEEDED @map("succeeded")
  FAILED    @map("failed")
  FALLBACK  @map("fallback")

  @@map("llm_call_status")
}

enum CustomerAssetRecordStatus {
  ACTIVE   @map("active")
  ARCHIVED @map("archived")

  @@map("customer_asset_record_status")
}

enum CustomerIdentityStatus {
  ACTIVE   @map("active")
  MERGED   @map("merged")
  ARCHIVED @map("archived")

  @@map("customer_identity_status")
}

enum CustomFieldValueType {
  TEXT    @map("text")
  NUMBER  @map("number")
  BOOLEAN @map("boolean")
  DATE    @map("date")
  JSON    @map("json")

  @@map("custom_field_value_type")
}

enum TagTargetKind {
  CUSTOMER @map("customer")

  @@map("tag_target_kind")
}

model Org {
  id                    String                   @id @default(uuid()) @db.Uuid
  slug                  String                   @unique @db.Text
  name                  String                   @db.Text
  status                PlatformRecordStatus     @default(ACTIVE)
  createdAt             DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  auditLogs             AuditLog[]
  configVersions        ConfigVersion[]
  tenants               Tenant[]
  orgMembers            OrgMember[]
  tenantMembers         TenantMember[]
  permissionGrants      PermissionGrant[]
  channelConnections    ChannelConnection[]
  telegramUpdateDedupes TelegramUpdateDedupe[]
  conversations         ChannelConversation[]
  conversationMessages  ChannelMessage[]
  supportTickets        SupportTicket[]
  supportTicketEvents   SupportTicketEvent[]
  customers             Customer[]
  customerIdentities    CustomerIdentity[]
  customFieldDefinitions CustomFieldDefinition[]
  customerFieldValues   CustomerFieldValue[]
  tagDefinitions        TagDefinition[]
  tagAssignments        TagAssignment[]
  kbEntries             KbRecord[]
  kbStages              KbStage[]
  mediaAssets           MediaAsset[]
  quoteRecords          QuoteRecord[]
  evalCases             EvalCase[]
  evalRuns              EvalRun[]
  evalResults           EvalResult[]
  evalGates             EvalGate[]
  llmCallLogs           LlmCallLog[]

  @@map("org")
}

model Tenant {
  id                    String                   @id @default(uuid()) @db.Uuid
  orgId                 String                   @map("org_id") @db.Uuid
  slug                  String                   @db.Text
  name                  String                   @db.Text
  status                PlatformRecordStatus     @default(ACTIVE)
  createdAt             DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  auditLogs             AuditLog[]
  configVersions        ConfigVersion[]
  org                   Org                      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tenantMembers         TenantMember[]
  permissionGrants      PermissionGrant[]
  channelConnections    ChannelConnection[]
  telegramUpdateDedupes TelegramUpdateDedupe[]
  conversations         ChannelConversation[]
  conversationMessages  ChannelMessage[]
  supportTickets        SupportTicket[]
  supportTicketEvents   SupportTicketEvent[]
  customers             Customer[]
  customerIdentities    CustomerIdentity[]
  customFieldDefinitions CustomFieldDefinition[]
  customerFieldValues   CustomerFieldValue[]
  tagDefinitions        TagDefinition[]
  tagAssignments        TagAssignment[]
  kbEntries             KbRecord[]
  kbStages              KbStage[]
  mediaAssets           MediaAsset[]
  quoteRecords          QuoteRecord[]
  evalCases             EvalCase[]
  evalRuns              EvalRun[]
  evalResults           EvalResult[]
  evalGates             EvalGate[]
  llmCallLogs           LlmCallLog[]

  @@unique([orgId, id])
  @@unique([orgId, slug])
  @@index([orgId])
  @@map("tenant")
}

model OrgMember {
  orgId        String                   @map("org_id") @db.Uuid
  userId       String                   @map("user_id") @db.Uuid
  role         String                   @db.Text
  status       PlatformMembershipStatus @default(ACTIVE)
  cacheVersion Int                      @default(1) @map("cache_version")
  createdAt    DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  org          Org                      @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([orgId, userId])
  @@index([userId, status])
  @@map("org_member")
}

model TenantMember {
  orgId            String                   @map("org_id") @db.Uuid
  tenantId         String                   @map("tenant_id") @db.Uuid
  userId           String                   @map("user_id") @db.Uuid
  role             String                   @db.Text
  status           PlatformMembershipStatus @default(ACTIVE)
  cacheVersion     Int                      @default(1) @map("cache_version")
  createdAt        DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  org              Org                      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tenant           Tenant                   @relation(fields: [orgId, tenantId], references: [orgId, id], onDelete: Cascade)
  permissionGrants PermissionGrant[]

  @@id([orgId, tenantId, userId])
  @@index([userId, status])
  @@index([orgId, userId, status])
  @@map("tenant_member")
}

model PermissionGrant {
  orgId        String       @map("org_id") @db.Uuid
  tenantId     String       @map("tenant_id") @db.Uuid
  userId       String       @map("user_id") @db.Uuid
  permission   String       @db.Text
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  org          Org          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tenant       Tenant       @relation(fields: [orgId, tenantId], references: [orgId, id], onDelete: Cascade)
  tenantMember TenantMember @relation(fields: [orgId, tenantId, userId], references: [orgId, tenantId, userId], onDelete: Cascade)

  @@id([orgId, tenantId, userId, permission])
  @@index([userId, tenantId])
  @@map("permission_grant")
}

model ConfigVersion {
  id                  String              @id @default(uuid()) @db.Uuid
  orgId               String              @map("org_id") @db.Uuid
  tenantId            String              @map("tenant_id") @db.Uuid
  domain              ConfigVersionDomain @map("config_domain")
  key                 String              @map("config_key") @db.Text
  version             Int
  status              ConfigVersionStatus @default(DRAFT)
  payload             Json
  createdByUserId     String              @map("created_by_user_id") @db.Uuid
  previousVersionId   String?             @map("previous_version_id") @db.Uuid
  rollbackOfVersionId String?             @map("rollback_of_version_id") @db.Uuid
  reason              String?             @db.Text
  createdAt           DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  activatedAt         DateTime?           @map("activated_at") @db.Timestamptz(6)
  org                 Org                 @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tenant              Tenant              @relation(fields: [orgId, tenantId], references: [orgId, id], onDelete: Cascade)
  previousVersion     ConfigVersion?      @relation("ConfigVersionPrevious", fields: [previousVersionId, orgId, tenantId, domain, key], references: [id, orgId, tenantId, domain, key], onDelete: Restrict)
  nextVersions        ConfigVersion[]     @relation("ConfigVersionPrevious")
  rollbackOfVersion   ConfigVersion?      @relation("ConfigVersionRollback", fields: [rollbackOfVersionId, orgId, tenantId, domain, key], references: [id, orgId, tenantId, domain, key], onDelete: Restrict)
  rollbackVersions    ConfigVersion[]     @relation("ConfigVersionRollback")
  auditLogsBefore     AuditLog[]          @relation("AuditLogBeforeVersion")
  auditLogsAfter      AuditLog[]          @relation("AuditLogAfterVersion")
  quoteRecords        QuoteRecord[]

  @@unique([id, orgId, tenantId, domain, key])
  @@unique([id, orgId, tenantId])
  @@unique([orgId, tenantId, domain, key, version])
  @@index([orgId, tenantId, domain, key, status])
  @@index([previousVersionId])
  @@index([rollbackOfVersionId])
  @@map("config_version")
}

model AuditLog {
  id              String         @id @default(uuid()) @db.Uuid
  orgId           String         @map("org_id") @db.Uuid
  tenantId        String         @map("tenant_id") @db.Uuid
  actorUserId     String         @map("actor_user_id") @db.Uuid
  eventType       String         @map("event_type") @db.Text
  module          String         @db.Text
  action          String         @db.Text
  objectType      String         @map("object_type") @db.Text
  objectId        String?        @map("object_id") @db.Text
  content         Json
  beforeVersionId String?        @map("before_version_id") @db.Uuid
  afterVersionId  String?        @map("after_version_id") @db.Uuid
  traceId         String?        @map("trace_id") @db.Text
  occurredAt      DateTime       @default(now()) @map("occurred_at") @db.Timestamptz(6)
  org             Org            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tenant          Tenant         @relation(fields: [orgId, tenantId], references: [orgId, id], onDelete: Cascade)
  beforeVersion   ConfigVersion? @relation("AuditLogBeforeVersion", fields: [beforeVersionId, orgId, tenantId], references: [id, orgId, tenantId], onDelete: Restrict)
  afterVersion    ConfigVersion? @relation("AuditLogAfterVersion", fields: [afterVersionId, orgId, tenantId], references: [id, orgId, tenantId], onDelete: Restrict)

  @@index([orgId, tenantId, occurredAt])
  @@index([eventType, occurredAt])
  @@index([objectType, objectId])
  @@map("audit_log")
}

model ChannelConnection {
  id                    String                   @id @default(uuid()) @db.Uuid
  orgId                 String                   @map("org_id") @db.Uuid
  tenantId              String                   @map("tenant_id") @db.Uuid
  provider              String                   @db.Text
  externalAccountRef    String                   @map("external_account_ref") @db.Text
  displayName           String?                  @map("display_name") @db.Text
  status                ChannelConnectionStatus  @default(ACTIVE)
  capabilities          Json
  metadata              Json
  createdAt             DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  org                   Org                      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tenant                Tenant                   @relation(fields: [orgId, tenantId], references: [orgId, id], onDelete: Cascade)
  telegramUpdateDedupes TelegramUpdateDedupe[]
  conversations         ChannelConversation[]
  messages              ChannelMessage[]
  customerIdentities    CustomerIdentity[]

  @@unique([id, orgId, tenantId])
  @@unique([orgId, tenantId, provider, externalAccountRef])
  @@index([orgId, tenantId, status])
  @@map("channel_connection")
}

model TelegramUpdateDedupe {
  id                  String            @id @default(uuid()) @db.Uuid
  orgId               String            @map("org_id") @db.Uuid
  tenantId            String            @map("tenant_id") @db.Uuid
  channelConnectionId String            @map("channel_connection_id") @db.Uuid
  providerUpdateId    String            @map("provider_update_id") @db.Text
  updateKind          String?           @map("update_kind") @db.Text
  receivedAt          DateTime          @default(now()) @map("received_at") @db.Timestamptz(6)
  processedAt         DateTime?         @map("processed_at") @db.Timestamptz(6)
  createdAt           DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  org                 Org               @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tenant              Tenant            @relation(fields: [orgId, tenantId], references: [orgId, id], onDelete: Cascade)
  channelConnection   ChannelConnection @relation(fields: [channelConnectionId, orgId, tenantId], references: [id, orgId, tenantId], onDelete: Cascade)

  @@unique([orgId, tenantId, channelConnectionId, providerUpdateId])
  @@index([orgId, tenantId, receivedAt])
  @@map("telegram_update_dedupe")
}

model ChannelConversation {
  id                      String                @id @default(uuid()) @db.Uuid
  orgId                   String                @map("org_id") @db.Uuid
  tenantId                String                @map("tenant_id") @db.Uuid
  channelConnectionId     String                @map("channel_connection_id") @db.Uuid
  externalConversationRef String                @map("external_conversation_ref") @db.Text
  participantExternalRef  String                @map("participant_external_ref") @db.Text
  status                  ConversationStatus    @default(OPEN)
  unreadCount             Int                   @default(0) @map("unread_count")
  lastMessageAt           DateTime?             @map("last_message_at") @db.Timestamptz(6)
  createdAt               DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  org                     Org                   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tenant                  Tenant                @relation(fields: [orgId, tenantId], references: [orgId, id], onDelete: Cascade)
  channelConnection       ChannelConnection     @relation(fields: [channelConnectionId, orgId, tenantId], references: [id, orgId, tenantId], onDelete: Cascade)
  messages                ChannelMessage[]
  tickets                 SupportTicket[]
  quoteRecords            QuoteRecord[]

  @@unique([id, orgId, tenantId])
  @@unique([orgId, tenantId, channelConnectionId, externalConversationRef])
  @@index([orgId, tenantId, status, updatedAt])
  @@map("conversation")
}

model ChannelMessage {
  id                  String                @id @default(uuid()) @db.Uuid
  orgId               String                @map("org_id") @db.Uuid
  tenantId            String                @map("tenant_id") @db.Uuid
  conversationId      String                @map("conversation_id") @db.Uuid
  channelConnectionId String                @map("channel_connection_id") @db.Uuid
  direction           MessageDirection
  contentKind         MessageContentKind    @map("content_kind")
  deliveryStatus      MessageDeliveryStatus @default(RECEIVED) @map("delivery_status")
  externalMessageRef  String?               @map("external_message_ref") @db.Text
  content             Json
  occurredAt          DateTime              @map("occurred_at") @db.Timestamptz(6)
  createdAt           DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  org                 Org                   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tenant              Tenant                @relation(fields: [orgId, tenantId], references: [orgId, id], onDelete: Cascade)
  conversation        ChannelConversation   @relation(fields: [conversationId, orgId, tenantId], references: [id, orgId, tenantId], onDelete: Cascade)
  channelConnection   ChannelConnection     @relation(fields: [channelConnectionId, orgId, tenantId], references: [id, orgId, tenantId], onDelete: Cascade)

  @@unique([id, orgId, tenantId])
  @@unique([orgId, tenantId, channelConnectionId, externalMessageRef])
  @@index([orgId, tenantId, conversationId, occurredAt])
  @@map("message")
}

model SupportTicket {
  id             String               @id @default(uuid()) @db.Uuid
  orgId          String               @map("org_id") @db.Uuid
  tenantId       String               @map("tenant_id") @db.Uuid
  conversationId String               @map("conversation_id") @db.Uuid
  status         TicketStatus         @default(OPEN)
  priority       Int                  @default(3)
  assignedUserId String?              @map("assigned_user_id") @db.Uuid
  lockedByUserId String?              @map("locked_by_user_id") @db.Uuid
  summary        String?              @db.Text
  slaDueAt       DateTime?            @map("sla_due_at") @db.Timestamptz(6)
  closedAt       DateTime?            @map("closed_at") @db.Timestamptz(6)
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  org            Org                  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tenant         Tenant               @relation(fields: [orgId, tenantId], references: [orgId, id], onDelete: Cascade)
  conversation   ChannelConversation  @relation(fields: [conversationId, orgId, tenantId], references: [id, orgId, tenantId], onDelete: Cascade)
  events         SupportTicketEvent[]

  @@unique([id, orgId, tenantId])
  @@index([orgId, tenantId, status, updatedAt])
  @@index([assignedUserId, status])
  @@map("ticket")
}

model SupportTicketEvent {
  id          String          @id @default(uuid()) @db.Uuid
  orgId       String          @map("org_id") @db.Uuid
  tenantId    String          @map("tenant_id") @db.Uuid
  ticketId    String          @map("ticket_id") @db.Uuid
  eventType   TicketEventType @map("event_type")
  actorUserId String?         @map("actor_user_id") @db.Uuid
  payload     Json
  occurredAt  DateTime        @default(now()) @map("occurred_at") @db.Timestamptz(6)
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  org         Org             @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tenant      Tenant          @relation(fields: [orgId, tenantId], references: [orgId, id], onDelete: Cascade)
  ticket      SupportTicket   @relation(fields: [ticketId, orgId, tenantId], references: [id, orgId, tenantId], onDelete: Cascade)

  @@index([orgId, tenantId, ticketId, occurredAt])
  @@map("ticket_event")
}

model Customer {
  id                   String                    @id @default(uuid()) @db.Uuid
  orgId                String                    @map("org_id") @db.Uuid
  tenantId             String                    @map("tenant_id") @db.Uuid
  displayLabelRef      String?                   @map("display_label_ref") @db.Text
  preferredLanguage    String?                   @map("preferred_language") @db.Text
  preferredScript      String?                   @map("preferred_script") @db.Text
  journeyStage         String?                   @map("journey_stage") @db.Text
  unresolvedIssueCount Int                       @default(0) @map("unresolved_issue_count")
  isBlacklisted        Boolean                   @default(false) @map("is_blacklisted")
  blacklistedAt        DateTime?                 @map("blacklisted_at") @db.Timestamptz(6)
  isUnreachable        Boolean                   @default(false) @map("is_unreachable")
  unreachableAt        DateTime?                 @map("unreachable_at") @db.Timestamptz(6)
  status               CustomerAssetRecordStatus @default(ACTIVE)
  metadata             Json                      @default("{}")
  createdAt            DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(6)
  org                  Org                       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tenant               Tenant                    @relation(fields: [orgId, tenantId], references: [orgId, id], onDelete: Cascade)
  identities           CustomerIdentity[]
  fieldValues          CustomerFieldValue[]
  tagAssignments       TagAssignment[]

  @@unique([id, orgId, tenantId])
  @@index([orgId, tenantId, status, updatedAt])
  @@index([orgId, tenantId, isBlacklisted, isUnreachable])
  @@map("customer")
}

model CustomerIdentity {
  id                  String                 @id @default(uuid()) @db.Uuid
  orgId               String                 @map("org_id") @db.Uuid
  tenantId            String                 @map("tenant_id") @db.Uuid
  customerId          String                 @map("customer_id") @db.Uuid
  channelConnectionId String?                @map("channel_connection_id") @db.Uuid
  identityKind        String                 @map("identity_kind") @db.Text
  provider            String                 @db.Text
  externalSubjectRef  String                 @map("external_subject_ref") @db.Text
  status              CustomerIdentityStatus @default(ACTIVE)
  firstSeenAt         DateTime               @default(now()) @map("first_seen_at") @db.Timestamptz(6)
  lastSeenAt          DateTime?              @map("last_seen_at") @db.Timestamptz(6)
  metadata            Json                   @default("{}")
  createdAt           DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  org                 Org                    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tenant              Tenant                 @relation(fields: [orgId, tenantId], references: [orgId, id], onDelete: Cascade)
  customer            Customer               @relation(fields: [customerId, orgId, tenantId], references: [id, orgId, tenantId], onDelete: Cascade)
  channelConnection   ChannelConnection?     @relation(fields: [channelConnectionId, orgId, tenantId], references: [id, orgId, tenantId], onDelete: Restrict)

  @@unique([id, orgId, tenantId])
  @@unique([orgId, tenantId, provider, externalSubjectRef])
  @@index([orgId, tenantId, customerId, status])
  @@index([channelConnectionId])
