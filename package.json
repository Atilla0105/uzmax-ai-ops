{
  "name": "uzmax-ai-ops",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.9.0",
  "engines": {
    "node": ">=20 <25"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/capabilities/*"
  ],
  "scripts": {
    "build": "npm run build:admin",
    "build:admin": "vite build apps/admin --emptyOutDir",
    "check": "npm run format:check && npm run typecheck && npm run lint && npm run depcruise && npm run jscpd && npm run knip && npm run guard:forbidden-terms && npm run guard:eval-triggers && npm run guard:pr-shape -- --base origin/main --spec docs/specs/M0-01-monorepo-ci-agents.md && npm run test && npm run size && npm run playwright",
    "depcruise": "depcruise apps packages --config dependency-cruiser.config.cjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "guard:eval-triggers": "node scripts/guards/eval-trigger-paths.mjs",
    "guard:forbidden-terms": "node scripts/guards/forbidden-terms.mjs",
    "guard:pr-shape": "node scripts/guards/pr-shape.mjs",
    "jscpd": "jscpd apps packages scripts --config jscpd.config.json",
    "knip": "knip --no-config-hints --no-tag-hints",
    "lint": "eslint .",
    "playwright": "playwright test",
    "size": "npm run build:admin && size-limit",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "size-limit": [
    {
      "name": "admin design harness",
      "path": "apps/admin/dist/assets/*.js",
      "limit": "250 KB"
    }
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@size-limit/file": "^12.1.0",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "dependency-cruiser": "^17.4.3",
    "eslint": "^10.5.0",
    "jscpd": "^5.0.9",
    "knip": "^6.16.1",
    "prettier": "^3.8.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "size-limit": "^12.1.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
